# _______________________ eSignet Configuration _______________________
ESIGNET_BASE_URL=http://localhost:9000

# OAuth2 Client credentials (On l'obtint après enregistrement avec eSignet)
CLIENT_ID=afya-local-client
CLIENT_SECRET=afya-local-secret

# Redirect URI registered with eSignet (must match exactly)
REDIRECT_URI=http://localhost:8000/auth/callback
JWT_AUDIENCE=
PRIVATE_KEY_PEM_PATH=./mock_idp/keys/client_private.pem

# _______________________ Firebase Configuration _______________________
FIREBASE_CREDENTIALS_JSON=./afya-id-firebase-adminsdk-fbsvc-2832f952d5.json

# Firebase project ID
FIREBASE_PROJECT_ID=afya-id
APP_ENV=development
ALLOW_FIREBASE_LOCAL_FALLBACK=true

# _____________________ Application Settings ________________________
# Base URL de ce backend API
APP_BASE_URL=http://localhost:8000
# Frontend URL pour CORS et post-login redirect
FRONTEND_URL=http://localhost:3000
# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:8000
# Secret key for session/state signing
APP_SECRET_KEY=change-this-to-a-random-secret-key
