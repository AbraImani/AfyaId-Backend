# ─── eSignet Configuration ───────────────────────────────────────
# Base URL for eSignet IdP (discovery endpoint will be auto-fetched)
# For testing with Mock ID: https://esignet-mock.collab.mosip.net
ESIGNET_BASE_URL=https://esignet-mock.collab.mosip.net

# OAuth2 Client credentials (obtained after registering with eSignet)
CLIENT_ID=your_client_id_here
CLIENT_SECRET=your_client_secret_here

# Redirect URI registered with eSignet (must match exactly)
REDIRECT_URI=http://localhost:8000/auth/callback

# Expected JWT audience (leave empty to default to CLIENT_ID)
JWT_AUDIENCE=

# ─── Private Key for private_key_jwt authentication ──────────────
# Path to RSA private key PEM file (used to sign client_assertion JWT)
# Required for eSignet production; optional if CLIENT_SECRET is set
PRIVATE_KEY_PEM_PATH=

# ─── Firebase Configuration ─────────────────────────────────────
# Path to Firebase service account JSON credentials file
FIREBASE_CREDENTIALS_JSON=./afya-id-firebase-adminsdk-fbsvc-2832f952d5.json

# Firebase project ID
FIREBASE_PROJECT_ID=afya-id

# Runtime environment: development, staging, production
APP_ENV=development

# In-memory fallback for Firestore when cloud is unavailable
# Set to false in production to fail fast and ensure cloud-only persistence
ALLOW_FIREBASE_LOCAL_FALLBACK=true

# ─── Application Settings ───────────────────────────────────────
# Base URL of this backend API
APP_BASE_URL=http://localhost:8000

# Frontend URL for CORS and post-login redirect
FRONTEND_URL=http://localhost:3000

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:8000

# Secret key for session/state signing
APP_SECRET_KEY=change-this-to-a-random-secret-key
